{
  "name": "@pelatform/eslint-config",
  "version": "0.1.13",
  "description": "Common ESLint configuration.",
  "author": "Pelatform",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "clean": "tsc -b --clean && rimraf dist",
    "clean:all": "rimraf .turbo dist node_modules",
    "build": "tsc"
  },
  "repository": "github:pelatformlabs/toolkits",
  "homepage": "https://github.com/pelatformlabs/toolkits",
  "bugs": {
    "url": "https://github.com/pelatformlabs/toolkits/issues"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "pelatform",
    "eslint",
    "eslintconfig",
    "configuration",
    "config",
    "typescript",
    "linting",
    "code-style"
  ],
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint-config-turbo": "^2.9.17",
    "globals": "^17.6.0",
    "typescript-eslint": "^8.61.0"
  },
  "devDependencies": {
    "@pelatform/tsconfig": "workspace:^",
    "eslint": "^10.4.1",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "eslint": ">=9.30.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  }
}
